{
  "seed": 17,
  "dataset": {
    "name": "synthetic_retail",
    "n_series": 128,
    "days": 14,
    "hours": 24,
    "forecast_days": 1,
    "recent_days": 7,
    "valid_ratio": 0.15,
    "test_ratio": 0.15,
    "noise_std": 0.15,
    "stockout_rate": 0.06
  },
  "model": {
    "hidden_dim": 40,
    "global_dim": 4,
    "day_dim": 4,
    "hour_dim": 4,
    "interaction_dim": 3,
    "dropout": 0.1
  },
  "loss": {
    "reconstruction_weight": 0.02,
    "history_sales_weight": 0.05,
    "decouple_weight": 0.001
  },
  "train": {
    "batch_size": 64,
    "epochs": 1,
    "lr": 0.001,
    "weight_decay": 0.0001,
    "grad_clip": 1.0,
    "huber_delta": 25.0,
    "num_workers": 0,
    "pin_memory": false,
    "selection_metric": "valid_wape",
    "device": "auto",
    "output_dir": "runs/2-Exp-1_residual_diagnostics_smoke"
  },
  "analysis": {
    "output_dir": "runs/2-Exp-1_residual_diagnostics_smoke",
    "split": "train",
    "baseline_method": "same_hour_recent_mean",
    "batch_size": 64,
    "max_regression_rows": 50000
  },
  "experiments": []
}
