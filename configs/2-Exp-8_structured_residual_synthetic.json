{
  "seed": 17,
  "dataset": {
    "name": "structured_residual_retail",
    "n_series": 1000,
    "days": 35,
    "hours": 24,
    "forecast_days": 2,
    "recent_days": 7,
    "valid_ratio": 0.15,
    "test_ratio": 0.15,
    "noise_std": 0.2,
    "stockout_rate": 0.04,
    "residual_scale": 1.0
  },
  "model": {
    "hidden_dim": 128,
    "global_dim": 8,
    "local_dim": 8,
    "day_dim": 8,
    "hour_dim": 8,
    "interaction_dim": 6,
    "dropout": 0.1
  },
  "loss": {
    "decouple_weight": 0.01
  },
  "residual": {
    "baseline_method": "same_hour_recent_mean"
  },
  "swap_regularization": {
    "enabled": false,
    "weight": 0.05
  },
  "train": {
    "batch_size": 64,
    "epochs": 12,
    "lr": 0.001,
    "weight_decay": 0.0001,
    "grad_clip": 1.0,
    "num_workers": 0,
    "pin_memory": true,
    "selection_metric": "valid_loss_residual_reconstruction",
    "device": "auto",
    "output_dir": "runs/2-Exp-8_structured_residual_synthetic"
  },
  "experiments": [
    {"name": "single_local_reference", "type": "multigrain_ae", "use_global": true, "use_local": true, "use_day": false, "use_hour": false, "use_interaction": false},
    {"name": "day_hour_no_swap", "type": "multigrain_ae", "use_global": true, "use_local": false, "use_day": true, "use_hour": true, "use_interaction": false},
    {
      "name": "day_hour_with_swap",
      "type": "multigrain_ae",
      "use_global": true,
      "use_local": false,
      "use_day": true,
      "use_hour": true,
      "use_interaction": false,
      "swap_regularization_overrides": {"enabled": true, "weight": 0.05}
    },
    {"name": "interaction_no_swap", "type": "multigrain_ae", "use_global": true, "use_local": false, "use_day": true, "use_hour": true, "use_interaction": true},
    {
      "name": "interaction_with_swap",
      "type": "multigrain_ae",
      "use_global": true,
      "use_local": false,
      "use_day": true,
      "use_hour": true,
      "use_interaction": true,
      "swap_regularization_overrides": {"enabled": true, "weight": 0.05}
    }
  ]
}
