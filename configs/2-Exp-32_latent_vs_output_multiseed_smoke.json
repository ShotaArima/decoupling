{
  "seed": 17,
  "sweep": {
    "seeds": [17, 23],
    "output_dir": "runs/2-Exp-32_latent_vs_output_multiseed_smoke",
    "scenarios": [
      {
        "name": "series_mean",
        "overrides": {}
      }
    ]
  },
  "dataset": {
    "name": "synthetic_retail",
    "n_series": 128,
    "days": 14,
    "hours": 24,
    "forecast_days": 1,
    "recent_days": 7,
    "valid_ratio": 0.15,
    "test_ratio": 0.15,
    "noise_std": 0.15,
    "stockout_rate": 0.06
  },
  "model": {
    "hidden_dim": 40,
    "global_dim": 4,
    "local_dim": 4,
    "day_dim": 4,
    "hour_dim": 4,
    "interaction_dim": 3,
    "dropout": 0.1
  },
  "loss": {
    "decouple_weight": 0.001,
    "component_constraint_weight": 0.0,
    "residual_bias_weight": 0.0,
    "series_residual_bias_weight": 0.0
  },
  "residual": {
    "baseline_method": "series_mean",
    "target": "baseline_residual"
  },
  "diagnostics": {
    "n_permutations": 0
  },
  "calibration": {
    "enabled": false
  },
  "swap_regularization": {
    "enabled": false,
    "weight": 0.05
  },
  "probes": {
    "enabled": false
  },
  "output": {
    "save_latent_arrays": false,
    "save_residual_predictions": false,
    "save_checkpoints": false,
    "save_hour_heatmap": false,
    "save_visualization_tables": false
  },
  "train": {
    "batch_size": 32,
    "epochs": 1,
    "lr": 0.001,
    "weight_decay": 0.0001,
    "grad_clip": 1.0,
    "num_workers": 0,
    "pin_memory": false,
    "amp": true,
    "reset_seed_per_variant": true,
    "selection_metric": "valid_loss_residual_reconstruction",
    "device": "auto",
    "output_dir": "runs/2-Exp-32_latent_vs_output_multiseed_smoke/base"
  },
  "experiments": [
    {
      "name": "paper_global_local_residual",
      "type": "multigrain_ae",
      "use_global": true,
      "use_local": true,
      "use_day": false,
      "use_hour": false,
      "use_interaction": false
    },
    {
      "name": "four_factor_global_day_hour_residual",
      "type": "multigrain_ae",
      "use_global": true,
      "use_local": false,
      "use_day": true,
      "use_hour": true,
      "use_interaction": false
    },
    {
      "name": "four_factor_global_day_hour_interaction_residual",
      "type": "multigrain_ae",
      "use_global": true,
      "use_local": false,
      "use_day": true,
      "use_hour": true,
      "use_interaction": true
    },
    {
      "name": "output_decomp_no_center",
      "type": "output_decomposition",
      "center_components": false,
      "use_interaction": true
    },
    {
      "name": "output_decomp_centered_no_interaction",
      "type": "output_decomposition",
      "center_components": true,
      "use_interaction": false
    },
    {
      "name": "output_decomp_centered",
      "type": "output_decomposition",
      "center_components": true,
      "use_interaction": true
    }
  ]
}
