{
  "seed": 37,
  "dataset": {
    "name": "synthetic_retail",
    "n_series": 800,
    "days": 28,
    "hours": 24,
    "forecast_days": 2,
    "recent_days": 7,
    "valid_ratio": 0.15,
    "test_ratio": 0.15,
    "noise_std": 0.15,
    "stockout_rate": 0.12
  },
  "model": {
    "hidden_dim": 96,
    "global_dim": 8,
    "day_dim": 8,
    "hour_dim": 8,
    "interaction_dim": 6,
    "dropout": 0.1
  },
  "loss": {
    "reconstruction_weight": 0.05,
    "history_sales_weight": 0.2,
    "decouple_weight": 0.01,
    "stockout_weighting": "mask",
    "stockout_weight": 0.1
  },
  "train": {
    "batch_size": 64,
    "epochs": 30,
    "lr": 0.001,
    "weight_decay": 0.0001,
    "grad_clip": 1.0,
    "huber_delta": 25.0,
    "num_workers": 0,
    "pin_memory": true,
    "selection_metric": "valid_wape",
    "early_stopping_patience": 5,
    "early_stopping_min_delta": 0.0,
    "device": "auto",
    "output_dir": "runs/EXP-007_stockout_probe_heatmap_synthetic"
  },
  "experiments": [
    {"name": "proposed_stockout_mask", "type": "multigrain", "use_day": true, "use_hour": true, "use_interaction": false, "loss_overrides": {"stockout_weighting": "mask"}},
    {"name": "proposed_stockout_soft_0_1", "type": "multigrain", "use_day": true, "use_hour": true, "use_interaction": false, "loss_overrides": {"stockout_weighting": "soft", "stockout_weight": 0.1}},
    {"name": "proposed_stockout_uniform", "type": "multigrain", "use_day": true, "use_hour": true, "use_interaction": false, "loss_overrides": {"stockout_weighting": "uniform"}}
  ]
}
