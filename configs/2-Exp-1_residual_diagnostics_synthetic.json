{
  "seed": 17,
  "dataset": {
    "name": "synthetic_retail",
    "n_series": 800,
    "days": 28,
    "hours": 24,
    "forecast_days": 2,
    "recent_days": 7,
    "valid_ratio": 0.15,
    "test_ratio": 0.15,
    "noise_std": 0.15,
    "stockout_rate": 0.06
  },
  "model": {
    "hidden_dim": 96,
    "global_dim": 8,
    "day_dim": 8,
    "hour_dim": 8,
    "interaction_dim": 6,
    "dropout": 0.1
  },
  "loss": {
    "reconstruction_weight": 0.05,
    "history_sales_weight": 0.2,
    "decouple_weight": 0.01
  },
  "train": {
    "batch_size": 256,
    "epochs": 1,
    "lr": 0.001,
    "weight_decay": 0.0001,
    "grad_clip": 1.0,
    "huber_delta": 25.0,
    "num_workers": 0,
    "pin_memory": true,
    "selection_metric": "valid_wape",
    "device": "auto",
    "output_dir": "runs/2-Exp-1_residual_diagnostics_synthetic"
  },
  "analysis": {
    "output_dir": "runs/2-Exp-1_residual_diagnostics_synthetic",
    "split": "train",
    "baseline_method": "same_hour_recent_mean",
    "batch_size": 256,
    "max_regression_rows": 200000
  },
  "experiments": []
}
