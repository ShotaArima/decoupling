{
  "seed": 17,
  "dataset": {
    "name": "freshretailnet",
    "hf_name": "Dingdong-Inc/FreshRetailNet-50K",
    "data_dir": "data/freshretailnet",
    "train_split": "train",
    "eval_split": "eval",
    "sample_id_columns": ["store_id", "product_id"],
    "static_id_columns": [
      "city_id",
      "store_id",
      "management_group_id",
      "first_category_id",
      "second_category_id",
      "third_category_id",
      "product_id"
    ],
    "daily_numeric_columns": [
      "discount",
      "holiday_flag",
      "activity_flag",
      "precpt",
      "avg_temperature",
      "avg_humidity",
      "avg_wind_level"
    ],
    "hourly_sales_column": "hours_sale",
    "hourly_stock_column": "hours_stock_status",
    "stockout_value": 1,
    "history_days": 28,
    "forecast_days": 2,
    "recent_days": 7,
    "window_size": 24,
    "cache_dir": "data/freshretailnet/cache",
    "use_cache": true,
    "max_train_series": 2000,
    "max_eval_series": 500
  },
  "model": {
    "hidden_dim": 128,
    "global_dim": 8,
    "local_dim": 8,
    "day_dim": 8,
    "hour_dim": 8,
    "interaction_dim": 6,
    "dropout": 0.1
  },
  "loss": {
    "decouple_weight": 0.01
  },
  "residual": {
    "baseline_method": "same_hour_recent_mean"
  },
  "train": {
    "batch_size": 128,
    "epochs": 10,
    "lr": 0.001,
    "weight_decay": 0.0001,
    "grad_clip": 1.0,
    "num_workers": 2,
    "pin_memory": true,
    "selection_metric": "valid_loss_residual_reconstruction",
    "device": "auto",
    "output_dir": "runs/2-Exp-2_to_6_residual_freshretailnet"
  },
  "experiments": [
    {"name": "residual_flatten_ae", "type": "flatten_ae"},
    {"name": "residual_global_only", "type": "multigrain_ae", "use_global": true, "use_local": false, "use_day": false, "use_hour": false, "use_interaction": false},
    {"name": "residual_global_single_local", "type": "multigrain_ae", "use_global": true, "use_local": true, "use_day": false, "use_hour": false, "use_interaction": false},
    {"name": "residual_global_day_hour_no_decouple", "type": "multigrain_ae", "use_global": true, "use_local": false, "use_day": true, "use_hour": true, "use_interaction": false, "loss_overrides": {"decouple_weight": 0.0}},
    {"name": "residual_global_day_hour", "type": "multigrain_ae", "use_global": true, "use_local": false, "use_day": true, "use_hour": true, "use_interaction": false},
    {"name": "residual_global_day_hour_interaction", "type": "multigrain_ae", "use_global": true, "use_local": false, "use_day": true, "use_hour": true, "use_interaction": true}
  ]
}
