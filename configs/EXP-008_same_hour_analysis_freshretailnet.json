{
  "seed": 31,
  "dataset": {
    "name": "freshretailnet",
    "hf_name": "Dingdong-Inc/FreshRetailNet-50K",
    "data_dir": "data/freshretailnet",
    "train_split": "train",
    "eval_split": "eval",
    "sample_id_columns": ["store_id", "product_id"],
    "static_id_columns": [
      "city_id",
      "store_id",
      "management_group_id",
      "first_category_id",
      "second_category_id",
      "third_category_id",
      "product_id"
    ],
    "daily_numeric_columns": [
      "discount",
      "holiday_flag",
      "activity_flag",
      "precpt",
      "avg_temperature",
      "avg_humidity",
      "avg_wind_level"
    ],
    "hourly_sales_column": "hours_sale",
    "hourly_stock_column": "hours_stock_status",
    "stockout_value": 1,
    "history_days": 28,
    "forecast_days": 2,
    "recent_days": 7,
    "window_size": 24,
    "cache_dir": "data/freshretailnet/cache",
    "use_cache": true,
    "max_train_series": 2000,
    "max_eval_series": 500
  },
  "analysis": {
    "batch_size": 256,
    "quantile_bins": 5,
    "output_dir": "runs/EXP-008_same_hour_analysis_freshretailnet",
    "ignore_missing_prediction_sources": true,
    "prediction_sources": [
      {
        "name": "feature_flatten_mlp",
        "path": "runs/EXP-006_baseline_comparability_freshretailnet/feature_flatten_mlp/predictions.csv"
      },
      {
        "name": "proposed_with_decouple",
        "path": "runs/EXP-006_baseline_comparability_freshretailnet/proposed_with_decouple/predictions.csv"
      }
    ]
  }
}
