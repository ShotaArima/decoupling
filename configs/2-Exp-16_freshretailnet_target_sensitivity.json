          },
          "dataset": {
            "subset_filter": {
              "enabled": false
            }
          }
        }
      },
      {
        "name": "same_hour_recent_mean_d1_all",
        "overrides": {
          "residual": {
            "baseline_method": "same_hour_recent_mean",
