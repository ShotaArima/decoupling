          },
          "dataset": {
            "subset_filter": {
              "enabled": false
            }
          }
        }
      },
      {
        "name": "same_hour_recent_mean_d3_all",
        "overrides": {
          "residual": {
            "baseline_method": "same_hour_recent_mean",
            "recent_days": 3
          },
          "dataset": {
            "subset_filter": {
              "enabled": false
            }
          }
        }
      },
      {
        "name": "same_hour_recent_mean_d7_all",
        "overrides": {
          "residual": {
            "baseline_method": "same_hour_recent_mean",
            "recent_days": 7
          },
          "dataset": {
            "subset_filter": {
              "enabled": false
            }
          }
        }
      },
      {
        "name": "log1p_same_hour_recent_mean_d7_all",
        "overrides": {
          "residual": {
            "baseline_method": "log1p_same_hour_recent_mean",
            "recent_days": 7
          },
          "dataset": {
            "subset_filter": {
              "enabled": false
            }
          }
        }
      },
      {
        "name": "series_mean_repro_top",
        "overrides": {
          "residual": {
            "baseline_method": "series_mean"
          },
          "dataset": {
            "subset_filter": {
              "enabled": true,
              "baseline_method": "series_mean",
              "sort_by": "residual_repro_score",
              "descending": true,
              "top_k": 1500,
              "min_nonzero_rate": 0.08,
              "min_observed_rate": 0.75
            }
          }
        }
      },
      {
        "name": "weekday_same_hour_mean_repro_top",
        "overrides": {
          "residual": {
            "baseline_method": "weekday_same_hour_mean"
          },
          "dataset": {
            "subset_filter": {
              "enabled": true,
              "baseline_method": "weekday_same_hour_mean",
              "sort_by": "residual_repro_score",
              "descending": true,
              "top_k": 1500,
              "min_nonzero_rate": 0.08,
              "min_observed_rate": 0.75
            }
          }
        }
      },
      {
        "name": "same_hour_recent_mean_d3_repro_top",
        "overrides": {
          "residual": {
            "baseline_method": "same_hour_recent_mean",
            "recent_days": 3
          },
          "dataset": {
            "subset_filter": {
              "enabled": true,
              "baseline_method": "same_hour_recent_mean",
              "recent_days": 3,
              "sort_by": "residual_repro_score",
              "descending": true,
              "top_k": 1500,
              "min_nonzero_rate": 0.08,
              "min_observed_rate": 0.75
            }
          }
        }
      },
      {
        "name": "log1p_same_hour_recent_mean_d7_repro_top",
        "overrides": {
          "residual": {
            "baseline_method": "log1p_same_hour_recent_mean",
            "recent_days": 7
          },
          "dataset": {
            "subset_filter": {
              "enabled": true,
              "baseline_method": "log1p_same_hour_recent_mean",
              "recent_days": 7,
              "sort_by": "residual_repro_score",
              "descending": true,
              "top_k": 1500,
              "min_nonzero_rate": 0.08,
              "min_observed_rate": 0.75
            }
          }
        }
      }
    ]
  },
  "dataset": {
    "name": "freshretailnet",
    "hf_name": "Dingdong-Inc/FreshRetailNet-50K",
    "data_dir": "data/freshretailnet",
    "train_split": "train",
    "eval_split": "eval",
    "sample_id_columns": ["store_id", "product_id"],
    "static_id_columns": [
      "city_id",
      "store_id",
      "management_group_id",
      "first_category_id",
      "second_category_id",
      "third_category_id",
      "product_id"
    ],
    "daily_numeric_columns": [
      "discount",
      "holiday_flag",
      "activity_flag",
      "precpt",
      "avg_temperature",
      "avg_humidity",
      "avg_wind_level"
    ],
    "hourly_sales_column": "hours_sale",
    "hourly_stock_column": "hours_stock_status",
    "stockout_value": 1,
    "history_days": 28,
    "forecast_days": 2,
    "recent_days": 7,
    "window_size": 24,
    "cache_dir": "data/freshretailnet/cache",
    "use_cache": true,
    "max_train_series": 6000,
    "max_eval_series": 1500,
    "subset_filter": {
      "enabled": false,
      "batch_size": 512,
      "structure_validation_fraction": 0.35,
      "min_effect_count": 4
    }
  },
  "model": {
    "hidden_dim": 160,
    "global_dim": 10,
    "local_dim": 10,
    "day_dim": 10,
    "hour_dim": 10,
    "interaction_dim": 8,
    "dropout": 0.1
  },
  "loss": {
    "decouple_weight": 0.01,
    "component_constraint_weight": 0.0,
    "residual_bias_weight": 0.0,
    "series_residual_bias_weight": 0.0
  },
  "residual": {
    "baseline_method": "same_hour_recent_mean",
    "target": "baseline_residual"
  },
  "calibration": {
    "enabled": false
  },
  "swap_regularization": {
    "enabled": false,
    "weight": 0.05
  },
  "train": {
    "batch_size": 128,
    "epochs": 10,
    "lr": 0.001,
    "weight_decay": 0.0001,
    "grad_clip": 1.0,
    "num_workers": 2,
    "pin_memory": true,
    "selection_metric": "valid_loss_residual_reconstruction",
    "device": "auto",
    "output_dir": "runs/2-Exp-16_freshretailnet_target_sensitivity/base"
  },
  "experiments": [
    {
      "name": "latent_concat_interaction",
      "type": "multigrain_ae",
      "use_global": true,
      "use_local": false,
      "use_day": true,
      "use_hour": true,
      "use_interaction": true
    },
    {
      "name": "output_decomp_centered",
      "type": "output_decomposition",
      "center_components": true,
      "use_interaction": true
    },
    {
      "name": "output_decomp_bias_loss_calibrated",
      "type": "output_decomposition",
      "center_components": true,
      "use_interaction": true,
      "loss_overrides": {
        "residual_bias_weight": 5.0,
        "series_residual_bias_weight": 1.0
      },
      "calibration_overrides": {
        "enabled": true,
        "mode": "validation_residual_bias",
        "clip_residual_quantile": 0.995
      }
    }
  ]
}
