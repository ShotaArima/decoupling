{
  "seed": 17,
  "sweep": {
    "seeds": [17, 23, 31],
    "output_dir": "runs/2-Exp-16_freshretailnet_target_sensitivity",
    "scenarios": [
      {
        "name": "series_mean_all",
        "overrides": {
          "residual": {
