{
  "seed": 17,
  "sweep": {
    "seeds": [17, 23, 31],
    "output_dir": "runs/2-Exp-10_factor_subsets_freshretailnet",
    "subsets": [
      {
        "name": "day_structured",
        "subset_filter": {
          "enabled": true,
          "batch_size": 512,
          "min_nonzero_rate": 0.08,
          "min_observed_rate": 0.75,
          "min_residual_std": 0.04,
          "sort_by": "weekday_variance_explained",
          "descending": true,
          "top_k": 800
        }
      },
      {
        "name": "hour_structured",
        "subset_filter": {
          "enabled": true,
          "batch_size": 512,
          "min_nonzero_rate": 0.08,
          "min_observed_rate": 0.75,
          "min_residual_std": 0.04,
          "sort_by": "hour_variance_explained",
          "descending": true,
          "top_k": 800
        }
      },
      {
        "name": "interaction_structured",
        "subset_filter": {
          "enabled": true,
          "batch_size": 512,
          "min_nonzero_rate": 0.08,
          "min_observed_rate": 0.75,
          "min_residual_std": 0.04,
          "sort_by": "interaction_nonadditive",
          "descending": true,
          "top_k": 800
        }
      },
      {
        "name": "clean_active",
        "subset_filter": {
          "enabled": true,
          "batch_size": 512,
          "min_nonzero_rate": 0.15,
          "min_observed_rate": 0.9,
          "min_residual_std": 0.04,
          "sort_by": "baseline_mae",
          "descending": true,
          "top_k": 800
        }
      }
    ]
  },
  "dataset": {
    "name": "freshretailnet",
    "hf_name": "Dingdong-Inc/FreshRetailNet-50K",
    "data_dir": "data/freshretailnet",
    "train_split": "train",
    "eval_split": "eval",
    "sample_id_columns": ["store_id", "product_id"],
    "static_id_columns": [
      "city_id",
      "store_id",
      "management_group_id",
      "first_category_id",
      "second_category_id",
      "third_category_id",
      "product_id"
    ],
    "daily_numeric_columns": [
      "discount",
      "holiday_flag",
      "activity_flag",
      "precpt",
      "avg_temperature",
      "avg_humidity",
      "avg_wind_level"
    ],
    "hourly_sales_column": "hours_sale",
    "hourly_stock_column": "hours_stock_status",
    "stockout_value": 1,
    "history_days": 28,
    "forecast_days": 2,
    "recent_days": 7,
    "window_size": 24,
    "cache_dir": "data/freshretailnet/cache",
    "use_cache": true,
    "max_train_series": 4000,
    "max_eval_series": 1000
  },
  "model": {
    "hidden_dim": 128,
    "global_dim": 8,
    "local_dim": 8,
    "day_dim": 8,
    "hour_dim": 8,
    "interaction_dim": 6,
    "dropout": 0.1
  },
  "loss": {
    "decouple_weight": 0.01
  },
  "residual": {
    "baseline_method": "same_hour_recent_mean"
  },
  "swap_regularization": {
    "enabled": false,
    "weight": 0.05
  },
  "train": {
    "batch_size": 128,
    "epochs": 8,
    "lr": 0.001,
    "weight_decay": 0.0001,
    "grad_clip": 1.0,
    "num_workers": 2,
    "pin_memory": true,
    "selection_metric": "valid_loss_residual_reconstruction",
    "device": "auto",
    "output_dir": "runs/2-Exp-10_factor_subsets_freshretailnet/base"
  },
  "experiments": [
    {"name": "interaction_no_swap", "type": "multigrain_ae", "use_global": true, "use_local": false, "use_day": true, "use_hour": true, "use_interaction": true},
    {
      "name": "interaction_with_swap",
      "type": "multigrain_ae",
      "use_global": true,
      "use_local": false,
      "use_day": true,
      "use_hour": true,
      "use_interaction": true,
      "swap_regularization_overrides": {"enabled": true, "weight": 0.05}
    }
  ]
}
