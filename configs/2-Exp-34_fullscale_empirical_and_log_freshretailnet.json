{
  "seed": 17,
  "sweep": {
    "seeds": [
      17,
      23,
      31
    ],
    "output_dir": "runs/2-Exp-34_fullscale_empirical_and_log",
    "scenarios": [
      {
        "name": "series_mean_all",
        "overrides": {
          "residual": {
            "baseline_method": "series_mean"
          }
        }
      },
      {
        "name": "same_hour_recent_mean_d7_all",
        "overrides": {
          "residual": {
            "baseline_method": "same_hour_recent_mean",
            "recent_days": 7
          }
        }
      },
      {
        "name": "log_series_mean_all",
        "overrides": {
          "residual": {
            "baseline_method": "log1p_series_mean"
          }
        }
      }
    ]
  },
  "dataset": {
    "name": "freshretailnet",
    "hf_name": "Dingdong-Inc/FreshRetailNet-50K",
    "data_dir": "data/freshretailnet",
    "train_split": "train",
    "eval_split": "eval",
    "sample_id_columns": [
      "store_id",
      "product_id"
    ],
    "static_id_columns": [
      "city_id",
      "store_id",
      "management_group_id",
      "first_category_id",
      "second_category_id",
      "third_category_id",
      "product_id"
    ],
    "daily_numeric_columns": [
      "discount",
      "holiday_flag",
      "activity_flag",
      "precpt",
      "avg_temperature",
      "avg_humidity",
      "avg_wind_level"
    ],
    "hourly_sales_column": "hours_sale",
    "hourly_stock_column": "hours_stock_status",
    "stockout_value": 1,
    "history_days": 28,
    "forecast_days": 2,
    "recent_days": 7,
    "window_size": 24,
    "cache_dir": "data/freshretailnet/cache",
    "use_cache": true,
    "max_train_series": 6000,
    "max_eval_series": 1500,
    "subset_filter": {
      "enabled": false,
      "batch_size": 512,
      "structure_validation_fraction": 0.35,
      "min_effect_count": 4
    },
    "validation_source": "train_holdout",
    "max_valid_series": 1500
  },
  "model": {
    "hidden_dim": 160,
    "global_dim": 10,
    "local_dim": 10,
    "day_dim": 10,
    "hour_dim": 10,
    "interaction_dim": 8,
    "dropout": 0.1
  },
  "loss": {
    "decouple_weight": 0.01,
    "component_constraint_weight": 0.0,
    "residual_bias_weight": 0.0,
    "series_residual_bias_weight": 0.0
  },
  "residual": {
    "baseline_method": "series_mean",
    "target": "baseline_residual"
  },
  "diagnostics": {
    "n_permutations": 500
  },
  "calibration": {
    "enabled": false
  },
  "swap_regularization": {
    "enabled": false,
    "weight": 0.05
  },
  "output": {
    "save_latent_arrays": false,
    "save_residual_predictions": false,
    "save_checkpoints": false,
    "save_hour_heatmap": true
  },
  "train": {
    "batch_size": 128,
    "epochs": 12,
    "lr": 0.001,
    "weight_decay": 0.0001,
    "grad_clip": 1.0,
    "num_workers": 2,
    "pin_memory": true,
    "selection_metric": "valid_loss_residual_reconstruction",
    "device": "auto",
    "output_dir": "runs/2-Exp-34_fullscale_empirical_and_log/base",
    "amp": true,
    "reset_seed_per_variant": true
  },
  "experiments": [
    {
      "name": "empirical_anova_main_effects",
      "type": "empirical_anova"
    },
    {
      "name": "output_decomp_centered",
      "type": "output_decomposition",
      "center_components": true,
      "use_interaction": true
    }
  ],
  "probes": {
    "enabled": false
  }
}